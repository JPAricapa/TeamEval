# ============================================================
# CONFIGURACIÓN DE ENTORNO - TeamEval Platform Backend
# Copiar a .env y completar los valores
# ============================================================

# Servidor
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Base de datos PostgreSQL
# Local:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/teameval?schema=public"
#
# Supabase + Prisma (recomendado para este proyecto):
# Usa la cadena "Supavisor Session pooler" que termina en :5432
# DATABASE_URL="postgresql://prisma.[PROJECT-REF]:[PASSWORD]@[REGION].pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres:password@localhost:5432/teameval?schema=public"

# JWT Secrets (usar valores seguros en producción)
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui_minimo_64_caracteres
JWT_REFRESH_SECRET=tu_refresh_secret_muy_seguro_aqui_minimo_64_caracteres
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logs
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Exportaciones
EXPORT_DIR=exports

# URL del frontend (para generar enlace de restablecimiento de contraseña)
FRONTEND_URL=http://localhost:5173

# Render + Vercel
# CORS_ORIGIN=https://tu-frontend.vercel.app
# FRONTEND_URL=https://tu-frontend.vercel.app

# Correo electrónico (nodemailer)
# Si no se configura EMAIL_HOST, el enlace se imprime en consola (modo desarrollo)
EMAIL_HOST=smtp.tuservidor.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu_usuario@correo.com
EMAIL_PASS=tu_contraseña_smtp
EMAIL_FROM="TeamEval <no-reply@teameval.edu.co>"
