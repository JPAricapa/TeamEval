# ============================================================
# CONFIGURACIÓN DE ENTORNO - TeamEval Platform Backend
# Copiar a .env y completar los valores
# ============================================================

# Servidor
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Base de datos local de desarrollo
DATABASE_URL="file:./dev.db"

# JWT Secrets (usar valores seguros en producción)
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui_minimo_64_caracteres
JWT_REFRESH_SECRET=tu_refresh_secret_muy_seguro_aqui_minimo_64_caracteres
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logs
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Exportaciones
EXPORT_DIR=exports

# URL del frontend (para generar enlace de restablecimiento de contraseña)
FRONTEND_URL=http://localhost:5173

# Correo electrónico (nodemailer)
# Si no se configura EMAIL_HOST, el enlace se imprime en consola (modo desarrollo)
EMAIL_HOST=smtp.tuservidor.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu_usuario@correo.com
EMAIL_PASS=tu_contraseña_smtp
EMAIL_FROM="TeamEval <no-reply@teameval.edu.co>"
